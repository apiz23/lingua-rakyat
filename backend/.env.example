# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to Git — it contains secret keys!
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM Provider ──────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT  → LLM_PROVIDER=ollama
# DEPLOYMENT         → LLM_PROVIDER=groq
LLM_PROVIDER=groq

# Ollama (local only)
OLLAMA_MODEL=phi3:mini
OLLAMA_BASE_URL=http://localhost:11434

# Groq (deployment)
# Get your API key at: https://console.groq.com
GROQ_API_KEY=PUT_YOUR_GROQ_API_KEY_HERE

# Models
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MODEL_FAST=llama-3.1-8b-instant


# ── Embedding Model ───────────────────────────────────────────────────────────
# Get your API key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=PUT_YOUR_COHERE_API_KEY_HERE


# ── Pinecone (Vector Database) ────────────────────────────────────────────────
# Get your API key at: https://app.pinecone.io
PINECONE_API_KEY=PUT_YOUR_PINECONE_API_KEY_HERE
PINECONE_INDEX=lingua-rakyat
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1


# ── Supabase Storage (File Storage) ──────────────────────────────────────────
# Get your keys at: https://app.supabase.com → Settings → API
SUPABASE_URL=PUT_YOUR_SUPABASE_URL_HERE
SUPABASE_KEY=PUT_YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE
SUPABASE_BUCKET=documents


# ── RAG Settings ──────────────────────────────────────────────────────────────
# Max number of document chunks to retrieve per question
TOP_K_CHUNKS=4


# ── WhatsApp Bot (Twilio) ─────────────────────────────────────────────────────
# Get keys at: https://console.twilio.com
TWILIO_ACCOUNT_SID=PUT_YOUR_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=PUT_YOUR_AUTH_TOKEN_HERE
# Self-referencing URL so whatsapp router can call the RAG pipeline internally
BACKEND_URL=https://lingua-rakyat-ai.vercel.app


# ── Rate Limits ───────────────────────────────────────────────────────────────
# At a demo booth every visitor shares one public IP, so per-IP limits fill fast.
# Set BOOTH_MODE=true during the demo for generous limits, false for normal use.
BOOTH_MODE=false
# Optional per-limit overrides (take precedence over BOOTH_MODE), e.g.:
# GLOBAL_RATE_LIMIT=2000/minute
# CHAT_RATE_LIMIT=300/minute
# VOICE_RATE_LIMIT=120/minute
# DOC_RATE_LIMIT=120/minute
# PDF_URL_RATE_LIMIT=240/minute
# SEED_RATE_LIMIT=30/minute